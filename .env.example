# Я.МЕДИПАЛ — Frontend
# Скопируйте как .env и заполните значения

# URL бэкенд-API
VITE_API_BASE_URL=http://localhost:4000/api

# Azure AD / MSAL (только для веб-версии, в Teams не используется)
VITE_MSAL_CLIENT_ID=
VITE_MSAL_AUTHORITY=https://login.microsoftonline.com/YOUR_TENANT_ID
VITE_MSAL_REDIRECT_URI=http://localhost:3000
VITE_API_SCOPE=api://YOUR_CLIENT_ID/access_as_user
